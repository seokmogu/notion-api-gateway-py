# Gateway-specific Notion API token with access to the Requests DB.
# Prefer this over generic NOTION_TOKEN so WDC and this service can keep
# separate Notion accounts/tokens in the same shell or host.
NOTION_GATEWAY_TOKEN=ntn_xxx

# Notion API version header.
NOTION_API_VERSION=2022-06-28

# Database used by the worker (Notion form target).
NOTION_GATEWAY_REQUESTS_DATABASE_ID=3297d832-2b04-8087-ab79-fd8dc364f884

# Browser automation settings.
NOTION_BROWSER_PROFILE_DIR=./data/notion-browser-profile
NOTION_HEADLESS=true
NOTION_INTEGRATION_NAME_PREFIX=API Access

# Optional automatic login for the admin browser session.
NOTION_GATEWAY_EMAIL=notion-automation@worxphere.ai
NOTION_GATEWAY_PASSWORD=
NOTION_GATEWAY_LOGIN_CODE=

# Optional workspace label used when Notion asks which workspace to associate.
NOTION_WORKSPACE_NAME=[Open] 웍스피어 스페이스

# Slack notification (optional). Create a bot at https://api.slack.com/apps
# Required scopes: chat:write, users:read.email, users:read
NOTION_GATEWAY_SLACK_BOT_TOKEN=

# Self-healing admin alert settings.
SELF_HEALING_ENABLED=true
SELF_HEALING_ADMIN_EMAIL=seokmogu@worxphere.ai
SELF_HEALING_ALERT_COOLDOWN_SECONDS=900

# External watchdog settings. The watchdog runs outside the poll worker and
# alerts when the worker is missing or its log is stale.
WATCHDOG_ADMIN_EMAIL=seokmogu@worxphere.ai
WATCHDOG_ALERT_COOLDOWN_SECONDS=900
WATCHDOG_POLL_STALE_SECONDS=300
WATCHDOG_POLL_LOG_PATH=operations/logs/poll.err.log
WATCHDOG_STATE_PATH=operations/logs/watchdog-state.json

# SSL settings (for corporate proxy with self-signed certificates).
NO_SSL_VERIFY=0
SSL_CA_FILE=

# Polling behavior.
REQUEST_POLL_INTERVAL_MS=15000
REQUEST_POLL_LIMIT=10
