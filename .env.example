# Notion API token with access to the Requests DB and requested pages.
NOTION_TOKEN=ntn_xxx

# Notion API version header.
NOTION_API_VERSION=2022-06-28

# Database used by the worker (Notion form target).
NOTION_REQUESTS_DATABASE_ID=replace-with-requests-database-id

# Browser automation settings.
NOTION_BROWSER_PROFILE_DIR=./data/notion-browser-profile
NOTION_HEADLESS=true
NOTION_INTEGRATION_NAME_PREFIX=API Access

# Optional automatic login for the admin browser session.
NOTION_EMAIL=
NOTION_PASSWORD=

# Optional workspace label used when Notion asks which workspace to associate.
NOTION_WORKSPACE_NAME=

# Slack notification (optional). Create a bot at https://api.slack.com/apps
# Required scopes: chat:write, users:read.email, users:read
SLACK_BOT_TOKEN=

# Polling behavior.
REQUEST_POLL_INTERVAL_MS=15000
REQUEST_POLL_LIMIT=10
